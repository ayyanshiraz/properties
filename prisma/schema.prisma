generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         Int        @id @default(autoincrement())
  name       String
  email      String     @unique
  phone      String
  password   String
  role       String     @default("USER")
  properties Property[]
  resetToken       String?
  resetTokenExpiry DateTime?
}

model Property {
  id            Int      @id @default(autoincrement())
  title         String
  type          String   
  category      String?
  area          String?
  price         String
  location      String
  description   String
  images        String[]
  videos        String[]
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  userId        Int?
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Naye Fields (Optional banaye hain taake purani properties break na hon)
  featuresList  String[] // 24 floors, Brands, Discounts waghera ke liye
  floorRates    Json?    // Pricing overview table ke liye
  paymentPlans  Json?    // Installments aur ROI data ke liye
}